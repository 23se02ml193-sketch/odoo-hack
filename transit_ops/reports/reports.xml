<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vehicle Report Action -->
    <record id="action_report_vehicle" model="ir.actions.report">
        <name>Vehicle Profile</name>
        <model>transit.vehicle</model>
        <report_type>qweb-pdf</report_type>
        <report_name>transit_ops.report_vehicle_template</report_name>
        <report_file>transit_ops.report_vehicle_template</report_file>
        <print_report_name>'Vehicle_%s' % (object.registration_no)</print_report_name>
        <binding_model_id ref="model_transit_vehicle"/>
        <binding_type>report</binding_type>
    </record>

    <!-- Trip Report Action -->
    <record id="action_report_trip" model="ir.actions.report">
